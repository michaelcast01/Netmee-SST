# PostgreSQL. Use a secret manager in production.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/netmee_epp"
# Supabase only: region shown in Dashboard > Connect (for example ca-central-1).
SUPABASE_REGION=""

# Authentication. Generate the secret with: npx auth@latest secret
BETTER_AUTH_URL="http://localhost:3000"
# Comma-separated exact origins for custom domains or approved previews.
BETTER_AUTH_TRUSTED_ORIGINS="https://netmee-sst.vercel.app"
BETTER_AUTH_SECRET="replace-with-at-least-32-random-characters"
AUTH_ALLOW_SIGNUP="false"

# Keep stable and identical across all application instances.
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY="replace-with-a-32-byte-base64-key"

# Transactional email for password recovery (Resend).
RESEND_API_KEY=""
EMAIL_FROM="NETMEE EPP Seguro <seguridad@example.com>"

# Initial administrator created by npm run db:seed.
SEED_ADMIN_NAME="Administrador NETMEE"
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="replace-with-a-strong-password"

# Optional AI-assisted PPE verification. Create a key at https://aistudio.google.com/apikey
# Keep this key server-side. The Gemini free tier may use submitted data to improve Google products.
AI_PROVIDER="gemini"
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-3.5-flash"
GEMINI_FALLBACK_MODELS="gemini-2.5-flash,gemini-flash-latest"
AI_CONFIDENCE_THRESHOLD="0.7"
AI_WORKER_SECRET="replace-with-a-random-worker-secret"
# Optional legacy/custom HTTP provider (set AI_PROVIDER="http").
AI_SERVICE_URL=""
AI_SERVICE_API_KEY=""
AI_MODEL_VERSION="ppe-detector-v1"
RETENTION_WORKER_SECRET="replace-with-a-random-retention-secret"
OBJECT_STORAGE_ENDPOINT=""
OBJECT_STORAGE_BUCKET="netmee-evidence"
OBJECT_STORAGE_REGION="us-east-1"
OBJECT_STORAGE_ACCESS_KEY=""
OBJECT_STORAGE_SECRET_KEY=""
